{
    "manifest_version": 3,
    "name": "Personify",
    "version": "0.1.0",
    "description": "Agentic AI for job application personal statements.",
    "permissions": ["storage", "activeTab", "scripting", "tabs"],
    "host_permissions": [
        "http://localhost:8000/*",
        "http://localhost:8081/*",
        "http://localhost:3000/*",
        "https://*.ashbyhq.com/*",
        "https://*.greenhouse.io/*",
        "https://*.myworkdayjobs.com/*"
    ],
    "background": {
        "service_worker": "src/background.js"
    },
    "content_scripts": [{
        "matches": [
            "http://localhost:8081/*",
            "https://*.ashbyhq.com/*",
            "https://*.greenhouse.io/*",
            "https://*.myworkdayjobs.com/*"
        ],
        "js": ["src/content_script.js"],
        "run_at": "document_idle"
    },
    {
        "matches": ["http://localhost:3000/*"],
        "js": ["src/install_detector.js"],
        "run_at": "document_idle"
    }],
    "action": {
        "default_popup": "src/popup.html",
        "default_title": "Personify"
    },
    "web_accessible_resources": [{
        "resources": ["src/popup.html", "src/popup.css", "src/popup.js", "icons/icon48.png", "icons/logo-transparent.png"],
        "matches": ["https://*.ashbyhq.com/*", "https://*.greenhouse.io/*", "https://*.myworkdayjobs.com/*"]
    }],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}